<?xml version="1.0" encoding="UTF-8"?>
<%
  sensor_type = camera_intrinsics['wideangle'] == true ? 'wideanglecamera' : 'camera'
  hfov_rad = camera_intrinsics['horizontal_fov_deg'].to_f * (Math::PI / 180.0)
%>
<sdf version='1.9'>
  <model name="sensor_camera">
    <link name="mono_cam/base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <!-- <mass>0.050</mass> -->
        <mass>0.001</mass>
        <inertia>
          <ixx>0.00004</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00004</iyy>
          <iyz>0</iyz>
          <izz>0.00004</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose degrees="true">0 0 0 0 -90 0</pose>
        <geometry>
          <cone>
            <radius>0.025</radius>
            <length>0.05</length>
          </cone>
        </geometry>
        <material>
          <ambient>1 1 0 1.0</ambient>
          <diffuse>1 1 0 1.0</diffuse>
        </material>
      </visual>
      <sensor name="imager" type="<%= sensor_type %>">
        <camera>
          <horizontal_fov><%= hfov_rad.round(6) %></horizontal_fov>
          <image>
            <width><%= camera_intrinsics['width'] %></width>
            <height><%= camera_intrinsics['height'] %></height>
          </image>
          <clip>
            <near><%= camera_intrinsics['near_clip'] %></near>
            <far><%= camera_intrinsics['far_clip'] %></far>
          </clip>
          <!-- TODO: https://www.seeedstudio.com/IMX219-200-Camera-200-FOV-Applicable-for-Jetson-Nano-p-4609.html -->
          <!-- Only for wideanglecamera, add lens options in https://github.com/gazebosim/gz-sensors/blob/main/src/WideAngleCameraSensor.cc -->
          <!-- Lens types: custom, equidistant, equisolid_angle, orthographic, gnomonical, stereographic -->
          <!--
          <lens>
            <type>custom</type>
            <custom_function>
              <c1>1.05</c1>
              <c2>4</c2>
              <f>1.0</f>
              <fun>tan</fun>
            </custom_function>
          </lens>
          -->
        </camera>
        <always_on>1</always_on>
        <update_rate><%= camera_intrinsics['update_rate'] %></update_rate>
        <visualize>false</visualize>
        <!-- <topic>rgb_camera</topic> -->
      </sensor>
      <gravity>true</gravity>
      <velocity_decay/>
    </link>
  </model>
</sdf>